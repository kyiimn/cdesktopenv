	$(MKCATDEFS) Uil $^ -h > Uil.tmp.msg
	LANG=C.utf8 $(GENCAT) $@ Uil.tmp.msg
	$(RM) Uil.tmp.msg

DtHelp.cat: $(TOPLIB)/DtHelp/DtHelp.msg
	$(RM) $@
	LANG=C.utf8 $(GENCAT) $@ $^

